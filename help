## Directory listing on linux ##

ip link

sudo ip link set ens33 up

sudo nano /etc/netplan/00-installer-config.yaml

network:
  version: 2
  ethernets:
    eth0:
      dhcp4: no
      addresses: [192.168.1.100/24]
      gateway4: 192.168.1.1
      nameservers:
        addresses: [8.8.8.8,8.8.4.4]

or

network:
  version: 2
  ethernets:
    ens33:
      dhcp4: yes

sudo netplan apply
